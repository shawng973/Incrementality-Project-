# Copy to .env and fill in values for local development.
# Never commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: use a local Postgres or the Supabase connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/incremental_tool_dev

# ── Redis / ARQ ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── JWT (must match the JWT secret in your Supabase project settings) ─────────
JWT_SECRET=your-supabase-jwt-secret

# ── LLM — OpenRouter ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Hot-swap the model without code changes:
LLM_MODEL=anthropic/claude-sonnet-4-5
LLM_SITE_URL=https://incremental-tool.terroir.com
LLM_SITE_NAME=Incremental Tool

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated additional CORS origins (add your Vercel URL in production)
# CORS_ORIGINS=https://incremental-tool.vercel.app,https://incremental-tool.terroir.com
